{
  "permissions": {
    "allow": [
      "Read(./.env.example)",
      "Edit(./.env.example)",
      "Write(./.env.example)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Bash(cat .env*)",
      "Bash(cat ./.env*)",
      "Bash(less .env*)",
      "Bash(less ./.env*)",
      "Bash(more .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)"
    ]
  }
}
