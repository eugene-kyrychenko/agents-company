# ============================================================
# AI Product Studio — environment configuration
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# ── LLM providers ───────────────────────────────────────────
# At minimum, set ANTHROPIC_API_KEY. Others optional for fallback/swap.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=

# LiteLLM proxy. Use 'localhost' if running orchestrator on the host (default).
# Switch to 'http://litellm:4000' only if you containerise the orchestrator.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-studio-local-master

# Model tier aliases (resolved by LiteLLM config.yaml)
MODEL_TIER_TACTICAL=haiku-4-5
MODEL_TIER_ANALYSIS=sonnet-4-6
MODEL_TIER_STRATEGIC=opus-4-7

# ── Budget guardrails ───────────────────────────────────────
DAILY_BUDGET_USD=3.00
MONTHLY_BUDGET_USD=100.00
PER_MESSAGE_TOKEN_LIMIT=2000

# ── Storage ─────────────────────────────────────────────────
# Use 'localhost' for host-run orchestrator (default). For containerised
# orchestrator override POSTGRES_HOST=postgres / REDIS_URL=redis://redis:6379/0.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=studio
POSTGRES_USER=studio
POSTGRES_PASSWORD=studio-local-dev

REDIS_URL=redis://localhost:6379/0

# ── Web search (Tavily) ─────────────────────────────────────
# Get a free key at tavily.com — leave blank to skip web search in dry-run.
TAVILY_API_KEY=

# ── Observability ───────────────────────────────────────────
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Discord (Phase 2 — leave blank for Phase 1 dry-run) ─────
DISCORD_BOT_TOKEN_CEO=
DISCORD_BOT_TOKEN_COO=
DISCORD_BOT_TOKEN_ANALYST=
DISCORD_BOT_TOKEN_FINANCE=
DISCORD_BOT_TOKEN_GROWTH=
DISCORD_BOT_TOKEN_PMM=
DISCORD_GUILD_ID=
DISCORD_FOUNDER_USER_ID=

# ── App config ──────────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
DRY_RUN=true

# Language for narrative output (Discord posts, prose).
# Supported: "en" (default), "uk". JSON keys + identifiers stay English.
STUDIO_LANGUAGE=en
